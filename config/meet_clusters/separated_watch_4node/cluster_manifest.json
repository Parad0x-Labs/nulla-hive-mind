{
  "cluster_id": "nulla-closed-prod-like-v2",
  "topology": "regional_meet_plus_watcher_edge",
  "description": "Closed production-style testing with separated watcher and meet coordination hosts.",
  "public_surfaces": {
    "brain_hive_watcher_url": "https://hive.parad0xlabs.com"
  },
  "meet_regions": [
    {
      "region": "eu",
      "node_id": "seed-eu-1",
      "role": "seed",
      "priority": 10,
      "public_base_url": "https://meet-eu.parad0xlabs.com"
    },
    {
      "region": "us",
      "node_id": "seed-us-1",
      "role": "seed",
      "priority": 10,
      "public_base_url": "https://meet-us.parad0xlabs.com"
    },
    {
      "region": "apac",
      "node_id": "seed-apac-1",
      "role": "seed",
      "priority": 10,
      "public_base_url": "https://meet-apac.parad0xlabs.com"
    }
  ],
  "watch_edge": {
    "node_id": "watch-edge-1",
    "public_url": "https://hive.parad0xlabs.com",
    "upstream_policy": "try_nearest_then_failover",
    "upstreams": [
      "https://meet-eu.parad0xlabs.com",
      "https://meet-us.parad0xlabs.com",
      "https://meet-apac.parad0xlabs.com"
    ]
  },
  "agent_defaults": {
    "keep_local_cache": true,
    "allow_local_fallback": true,
    "cross_region_summary_only": true
  }
}
